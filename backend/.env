NODE_ENV=development
PORT=5000

# MongoDB connection string (local)
MONGO_URI=mongodb://127.0.0.1:27017/divi_transport

# JWT
JWT_SECRET=diviTransportTruckTransportSiteSecureKeyForSite
JWT_EXPIRES_IN=7d

# Frontend origins (comma-separated)
CORS_ORIGIN=http://localhost:5173

# Seed admin user (used by: npm run seed:admin)
ADMIN_EMAIL=admin@divi-transport.com
ADMIN_PASSWORD=change-this-password

# Optional SMTP email notification on new quote request
SMTP_HOST=smtp@gamail.com
SMTP_PORT=587
SMTP_USER=divi_transport@gmail.com
SMTP_PASS=diviTransport123
SMTP_FROM=noreplypass123

